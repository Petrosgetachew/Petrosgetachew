<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Petros Getachew — Accountant & Data Analyst</title>
<meta name="description" content="Petros Getachew — Accountant, data analyst, and MS Accounting & Analytics candidate at UT Dallas. Portfolio of work in reconciliation, audit, and financial analysis." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=Inter+Tight:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0E1A2B;
    --ink-soft: #2C3A4F;
    --paper: #F6F1E8;
    --paper-warm: #EFE7D6;
    --gold: #B8893A;
    --gold-soft: #D4B574;
    --rule: #2C3A4F;
    --muted: #6B7689;
    --serif: 'Fraunces', 'Times New Roman', serif;
    --sans: 'Inter Tight', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* Subtle paper grain */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ==================== NAVIGATION ==================== */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(246, 241, 232, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(44, 58, 79, 0.08);
    transition: padding 0.3s ease;
  }

  nav.scrolled { padding: 1rem 3rem; }

  .logo {
    font-family: var(--serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.4rem;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .logo span { color: var(--gold); }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    position: relative;
    transition: color 0.3s ease;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.3s ease;
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a:hover::after { width: 100%; }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 32px;
    height: 32px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--ink);
    transition: 0.3s;
  }

  /* ==================== HERO ==================== */
  .hero {
    min-height: 100vh;
    padding: 8rem 3rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    position: relative;
    z-index: 2;
  }

  .hero-text { max-width: 600px; }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .eyebrow::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--gold);
  }

  .hero h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold);
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin-bottom: 2.5rem;
    line-height: 1.6;
    max-width: 480px;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }
  .hero-meta div {
    border-left: 2px solid var(--gold);
    padding-left: 1rem;
  }
  .hero-meta .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .hero-meta .value {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s 1s forwards;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.8rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }
  .btn-primary {
    background: var(--ink);
    color: var(--paper);
  }
  .btn-primary:hover {
    background: var(--gold);
    color: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(184, 137, 58, 0.3);
  }
  .btn-secondary {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
  }
  .btn-secondary:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .btn .arrow { transition: transform 0.3s ease; }
  .btn:hover .arrow { transform: translateX(4px); }

  /* Hero portrait/visual */
  .hero-visual {
    position: relative;
    aspect-ratio: 4/5;
    max-width: 480px;
    margin-left: auto;
    opacity: 0;
    animation: fadeIn 1.2s 0.8s forwards;
  }
  .portrait-frame {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--ink) 0%, var(--ink-soft) 100%);
    overflow: hidden;
    border-radius: 4px;
  }
  .portrait-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 12rem;
    color: var(--gold-soft);
    opacity: 0.95;
    letter-spacing: -0.05em;
  }
  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, transparent 0%, rgba(14, 26, 43, 0.4) 100%);
  }
  .deco-frame {
    position: absolute;
    inset: -20px -20px 20px 20px;
    border: 1px solid var(--gold);
    z-index: -1;
  }
  .deco-text {
    position: absolute;
    bottom: -50px;
    right: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* ==================== SECTIONS ==================== */
  section {
    padding: 8rem 3rem;
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 5rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: end;
  }
  .section-num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }
  .section-title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .section-title em {
    font-style: italic;
    color: var(--gold);
  }
  .section-intro {
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: 1.7;
    max-width: 540px;
  }

  /* ==================== ABOUT ==================== */
  .about {
    background: var(--paper-warm);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .about-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }
  .about-text p:first-child::first-letter {
    font-family: var(--serif);
    font-size: 4rem;
    font-weight: 400;
    float: left;
    line-height: 0.85;
    margin: 0.3rem 0.6rem 0 0;
    color: var(--gold);
  }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .stat {
    border-top: 2px solid var(--ink);
    padding-top: 1.5rem;
  }
  .stat-num {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }
  .stat-num em {
    font-style: italic;
    color: var(--gold);
    font-size: 0.5em;
    vertical-align: super;
  }
  .stat-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ==================== RESUME ==================== */
  .resume-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
  }
  .resume-aside {
    position: sticky;
    top: 7rem;
    align-self: start;
  }
  .resume-aside h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--ink);
  }
  .resume-aside p {
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .timeline { position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 12px;
    bottom: 12px;
    width: 1px;
    background: var(--ink-soft);
    opacity: 0.2;
  }
  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    padding-bottom: 3rem;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 8px;
    width: 9px;
    height: 9px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--paper);
  }
  .timeline-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .timeline-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--ink);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }
  .timeline-org {
    font-size: 0.95rem;
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: 1rem;
  }
  .timeline-item ul {
    list-style: none;
  }
  .timeline-item li {
    color: var(--ink-soft);
    line-height: 1.7;
    padding-left: 1.2rem;
    position: relative;
    margin-bottom: 0.6rem;
    font-size: 0.95rem;
  }
  .timeline-item li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  /* ==================== PROJECTS ==================== */
  .projects {
    background: var(--ink);
    color: var(--paper);
    padding-left: 0;
    padding-right: 0;
    max-width: none;
  }
  .projects-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
  }
  .projects .section-title { color: var(--paper); }
  .projects .section-intro { color: var(--paper-warm); }
  .projects .section-num { color: var(--gold-soft); }

  .project-list { margin-top: 3rem; }
  .project {
    display: grid;
    grid-template-columns: 80px 1fr 2fr 1fr;
    gap: 3rem;
    padding: 3rem 0;
    border-top: 1px solid rgba(246, 241, 232, 0.15);
    align-items: start;
    transition: padding 0.4s ease;
    cursor: default;
  }
  .project:last-child { border-bottom: 1px solid rgba(246, 241, 232, 0.15); }
  .project:hover { padding-left: 1.5rem; }
  .project:hover .project-title { color: var(--gold-soft); }

  .project-num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 1.5rem;
    color: var(--gold-soft);
  }
  .project-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.6rem;
    line-height: 1.2;
    color: var(--paper);
    transition: color 0.3s ease;
  }
  .project-desc {
    color: var(--paper-warm);
    line-height: 1.7;
    font-size: 0.95rem;
  }
  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .project-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-soft);
  }
  .project-result {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--paper);
    line-height: 1.4;
  }

  /* ==================== SKILLS ==================== */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .skill-card {
    background: var(--paper-warm);
    padding: 2.5rem;
    border-top: 3px solid var(--gold);
    transition: all 0.4s ease;
    position: relative;
  }
  .skill-card:hover {
    background: var(--ink);
    color: var(--paper);
    transform: translateY(-4px);
  }
  .skill-card:hover .skill-cat,
  .skill-card:hover h3,
  .skill-card:hover li { color: var(--paper); }
  .skill-card:hover li::before { color: var(--gold-soft); }

  .skill-cat {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 1rem;
    transition: color 0.3s ease;
  }
  .skill-card h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.6rem;
    margin-bottom: 1.5rem;
    color: var(--ink);
    line-height: 1.2;
    transition: color 0.3s ease;
  }
  .skill-card ul { list-style: none; }
  .skill-card li {
    padding: 0.5rem 0;
    color: var(--ink-soft);
    border-bottom: 1px solid rgba(44, 58, 79, 0.1);
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }
  .skill-card li:last-child { border-bottom: none; }

  /* ==================== EDUCATION ==================== */
  .education {
    background: var(--paper-warm);
  }
  .edu-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .edu-item {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(44, 58, 79, 0.15);
    align-items: start;
  }
  .edu-item:last-child { border-bottom: none; }
  .edu-date {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--gold);
  }
  .edu-degree {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .edu-school {
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: 0.75rem;
  }
  .edu-detail {
    color: var(--ink-soft);
    line-height: 1.7;
    font-size: 0.95rem;
  }
  .edu-meta {
    text-align: right;
  }
  .edu-gpa {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 2.5rem;
    color: var(--ink);
    line-height: 1;
  }
  .edu-gpa-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  /* ==================== CERTIFICATIONS ==================== */
  .certs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .cert {
    padding: 2.5rem;
    border: 1px solid rgba(44, 58, 79, 0.2);
    background: var(--paper);
    position: relative;
    transition: all 0.3s ease;
  }
  .cert:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }
  .cert::before {
    content: '◆';
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--gold);
    font-size: 0.8rem;
  }
  .cert-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.3rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    padding-right: 2rem;
  }
  .cert-org {
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  .cert-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    font-weight: 600;
  }

  /* ==================== CONTACT ==================== */
  .contact {
    background: var(--ink);
    color: var(--paper);
    text-align: center;
    padding: 8rem 3rem;
    max-width: none;
  }
  .contact .section-title { color: var(--paper); }
  .contact .section-title em { color: var(--gold-soft); }
  .contact .section-num { color: var(--gold-soft); }
  .contact-intro {
    max-width: 600px;
    margin: 0 auto 4rem;
    color: var(--paper-warm);
    font-size: 1.15rem;
    line-height: 1.7;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .contact-item {
    padding: 2rem;
    border: 1px solid rgba(246, 241, 232, 0.15);
    text-decoration: none;
    color: var(--paper);
    transition: all 0.3s ease;
  }
  .contact-item:hover {
    border-color: var(--gold);
    background: rgba(184, 137, 58, 0.08);
    transform: translateY(-4px);
  }
  .contact-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-soft);
    margin-bottom: 0.75rem;
  }
  .contact-value {
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--paper);
    word-break: break-word;
  }

  /* ==================== FOOTER ==================== */
  footer {
    background: var(--ink);
    color: var(--paper-warm);
    padding: 2.5rem 3rem;
    text-align: center;
    border-top: 1px solid rgba(246, 241, 232, 0.1);
    font-size: 0.85rem;
    position: relative;
    z-index: 2;
  }
  footer em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--gold-soft);
  }

  /* ==================== ANIMATIONS ==================== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 968px) {
    nav { padding: 1rem 1.5rem; }
    nav.scrolled { padding: 0.75rem 1.5rem; }
    .nav-toggle { display: flex; }
    .nav-links {
      position: absolute;
      top: 100%;
      right: 1.5rem;
      background: var(--paper);
      flex-direction: column;
      padding: 1.5rem 2rem;
      gap: 1rem;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: all 0.3s ease;
    }
    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .hero {
      grid-template-columns: 1fr;
      padding: 7rem 1.5rem 3rem;
      gap: 3rem;
    }
    .hero-visual { max-width: 320px; margin: 0 auto; }
    section { padding: 5rem 1.5rem; }
    .section-header {
